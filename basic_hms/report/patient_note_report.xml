          <t t-foreach='docs' t-as='doc'>
            <h3>Date: </h3>
            <t t-esc='doc.my_date'/>
            <br/>
            <br/>
            <br/>
            <h3>Patient Note: </h3>
            <t t-esc='doc.note'/>
          </t>
        </t>
      </template>
  </data>
</odoo>